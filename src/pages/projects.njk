---
layout: layouts/base.njk
title: Projects
permalink: /projects/
---

<section class="intro single">
    <div>
        <h2>Projects</h2>
        <p>A collection of things I've built—from group research projects to personal experiments.</p>
    </div>
</section>

{# Sort newest-first, then float ongoing ("… – Present") projects to the top #}
{% set sorted = collections.projects | sort(attribute='date') | reverse %}
{% set ongoing = [] %}
{% set finished = [] %}
{% for project in sorted %}
    {%- if project.data.date_range and 'Present' in project.data.date_range -%}
        {%- set _ = ongoing.push(project) -%}
    {%- else -%}
        {%- set _ = finished.push(project) -%}
    {%- endif -%}
{% endfor %}
{% set work = ongoing.concat(finished) %}
{% if work and work | length %}
<section>
    <div class="card-grid">
        {% for project in work %}
        <a class="card card--project" href="{{ project.url }}">
            {% if project.data.image %}
            <img src="{{ project.data.image }}" alt="{{ project.data.title }} preview" sizes="(max-width: 480px) 92vw, (max-width: 900px) 45vw, 300px">
            {% endif %}
            {% if project.data.tags %}
            <div class="tag-list">
                {% for tag in project.data.tags %}
                    {% if tag != 'projects' %}
                    <span class="tag-pill">{{ tag }}</span>
                    {% endif %}
                {% endfor %}
            </div>
            {% endif %}
            <p class="project-date">{{ project.data.date_range or (project.date | readableDate('monthYear')) }}</p>
            <h3>{{ project.data.title }}</h3>
            <p>{{ project.data.summary }}</p>
        </a>
        {% endfor %}
    </div>
</section>
{% else %}
<section>
    <p>Projects are being documented. Check back soon.</p>
</section>
{% endif %}
